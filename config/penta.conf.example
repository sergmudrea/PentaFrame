# Penta OS Configuration (example)
# Copy this file to /etc/penta/config.yaml and adjust to your needs.

hub:
  endpoint: "localhost:8400"
  refresh_interval: 21600
  cache_backend: "sqlite"
  peer_nodes: []

resolver:
  container_engine: "distrobox"
  default_image_registry: "ghcr.io/penta-os/toolboxes"
  auto_rollback: true
  hardware_profile: "auto"
  seccomp_profiles_dir: "/etc/penta/seccomp"
  apparmor_profiles_dir: "/etc/apparmor.d"
  temp_dir: "/var/tmp/penta-install"
  max_concurrent_installs: 2

modes:
  default: "desktop"
  services_dir: "/etc/penta/modes"

security:
  apparmor_enforce: true
  seccomp_enforce: true
  tpm: false
  measured_boot: false
  killswitch_gpio: 27

logging:
  level: "info"
  journald: true
  mqtt_topic: "penta/log"

mqtt:
  broker: "localhost"
  port: 1883
  client_id: "penta-os"
  keepalive: 60

psyched:
  sensor_mode: "emulate"
  emulate_interval: 5
  stress_threshold: 70
  fatigue_threshold: 80

mode_watcher:
  rules:
    - module_type: "HackRF"
      mode: "pentest"
    - module_type: "Zigbee"
      mode: "smarthome"
    - module_type: "GPU"
      mode: "desktop"
