#!/usr/bin/env python3
"""
penta - Penta OS Universal CLI (v1.6.4)
========================================
Command-line interface for installing, removing, searching software,
managing modes, and viewing system status. Communicates with Penta Resolver
and other Penta services via REST APIs.

New in v1.6.4:
  - Receives app metadata from Resolver after install and creates
    wrapper scripts and .desktop files locally for the current user.
  - Adds ~/.local/bin to PATH in .profile if missing.
  - Accepts --username to run operations on behalf of another user.

Usage:
    penta install <package> [--source <source>] [--username <user>]
    penta remove <app>
    penta list
    penta search <term>
    penta mode set <mode>
    penta module list
    penta system info
"""

import sys
import os
import stat
import subprocess
import time
from pathlib import Path

import click
import requests

# ---------- Configuration ----------
RESOLVER_URL = "http://localhost:8500"
PENTAD_URL = "http://localhost:8600"
HUB_URL = "http://localhost:8400"

USER_HOME = Path.home()
USER_BIN_DIR = USER_HOME / ".local" / "bin"
DESKTOP_DIR = USER_HOME / ".local" / "share" / "applications"

# ---------- Helper Functions ----------
def print_json(data):
    """Pretty-print JSON."""
    import json
    click.echo(json.dumps(data, indent=2))

def check_resolver():
    """Verify that the Penta Resolver is reachable."""
    try:
        r = requests.get(f"{RESOLVER_URL}/api/v1/health", timeout=2)
        if r.status_code != 200:
            click.echo("Penta Resolver is not healthy. Start the service first.")
            sys.exit(1)
    except requests.ConnectionError:
        click.echo("Cannot connect to Penta Resolver. Is it running?")
        sys.exit(1)

def create_wrapper_script(app_name: str, container: str, exec_name: str, is_windows: bool) -> Path:
    """
    Create an executable shell script in USER_BIN_DIR that runs the application
    in its container via distrobox.
    """
    USER_BIN_DIR.mkdir(parents=True, exist_ok=True)
    wrapper_path = USER_BIN_DIR / app_name
    # Handle name conflicts
    suffix = 0
    base = app_name
    while wrapper_path.exists():
        suffix += 1
        app_name = f"{base}_{suffix}"
        wrapper_path = USER_BIN_DIR / app_name

    if is_windows:
        launch_cmd = f"box64 wine {exec_name}"
    else:
        launch_cmd = exec_name

    script = f"""#!/bin/bash
# Penta OS wrapper for {app_name}
exec distrobox enter {container} -- {launch_cmd} "$@"
"""
    wrapper_path.write_text(script)
    wrapper_path.chmod(wrapper_path.stat().st_mode | stat.S_IEXEC | stat.S_IXGRP | stat.S_IXOTH)
    click.echo(f"  Wrapper created: {wrapper_path}")
    return wrapper_path

def create_desktop_file(name: str, wrapper_path: Path, icon: str = "") -> Path:
    """
    Create a .desktop entry that points to the wrapper script.
    """
    DESKTOP_DIR.mkdir(parents=True, exist_ok=True)
    desktop_file = DESKTOP_DIR / f"{name.replace(' ', '_')}.desktop"
    content = f"""[Desktop Entry]
Name={name}
Exec={wrapper_path}
Icon={icon}
Type=Application
Terminal=false
Categories=Utility;
"""
    desktop_file.write_text(content)
    desktop_file.chmod(0o755)
    subprocess.run(["update-desktop-database", str(DESKTOP_DIR)], capture_output=True)
    click.echo(f"  Desktop entry: {desktop_file}")
    return desktop_file

def ensure_path_in_profile():
    """Add ~/.local/bin to PATH in .profile if not already present."""
    profile = USER_HOME / ".profile"
    line = 'export PATH="$HOME/.local/bin:$PATH"'
    if profile.exists():
        content = profile.read_text()
        if line not in content:
            with profile.open("a") as f:
                f.write(f"\n# Penta OS\n{line}\n")
    else:
        profile.write_text(f"{line}\n")
    click.echo(f"  Added {USER_BIN_DIR} to PATH in {profile}")

# ---------- CLI Group ----------
@click.group()
def cli():
    """Penta OS - The Universal Package Manager"""
    pass

# ---------- Install ----------
@cli.command()
@click.argument("package")
@click.option("--source", "-s", default="auto",
              help="Source repository (apt, aur, pypi, homebrew, github, appimage, exe).")
@click.option("--username", "-u", default=None,
              help="Username under which to install (default: current user).")
def install(package, source, username):
    """Install a package from any supported ecosystem."""
    check_resolver()
    payload = {"package": package, "source": source}
    if username:
        payload["username"] = username
    else:
        payload["username"] = os.getlogin()

    try:
        r = requests.post(f"{RESOLVER_URL}/api/v1/install", json=payload)
        r.raise_for_status()
        task_id = r.json()["task_id"]
        click.echo(f"Installation started. Task ID: {task_id}")

        # Poll task until completion
        with click.progressbar(length=100, label="Installing") as bar:
            last_progress = 0
            while True:
                time.sleep(0.5)
                tr = requests.get(f"{RESOLVER_URL}/api/v1/task/{task_id}")
                task = tr.json()
                new_progress = task.get("progress", 0)
                bar.update(new_progress - last_progress)
                last_progress = new_progress
                # Print new log lines
                for line in task.get("log", [])[-3:]:
                    if line and line not in printed_logs:
                        click.echo(f"  {line}")
                        printed_logs.add(line)
                if task["status"] in ("completed", "failed"):
                    bar.update(100 - last_progress)
                    click.echo(f"\nStatus: {task['status']}")
                    if task["status"] == "completed" and task.get("result"):
                        # Create local wrappers and desktop entries
                        meta = task["result"]
                        app_name = meta.get("name", package)
                        exec_name = meta.get("exec_name", app_name)
                        container = meta.get("container", "debian-stable")
                        is_win = meta.get("is_windows", False)
                        icon = meta.get("icon_url", "")

                        wrapper = create_wrapper_script(exec_name, container, exec_name, is_win)
                        create_desktop_file(app_name, wrapper, icon)
                        ensure_path_in_profile()
                        click.echo(f"'{app_name}' is now available globally. You may need to restart your shell.")
                    elif task["status"] == "failed":
                        sys.exit(1)
                    break
    except requests.RequestException as e:
        click.echo(f"Error: {e}")
        sys.exit(1)

