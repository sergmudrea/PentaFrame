#!/usr/bin/env python3
"""
penta - Penta OS Universal CLI (v1.6.5)
========================================
Command-line interface for installing, removing, searching software,
managing modes, and viewing system status. Communicates with Penta Resolver
and other Penta services via REST APIs.

Changes in v1.6.5:
  - Connects to Hub and Resolver via Unix domain sockets by default.
  - Resolver URL: unix:///run/penta/resolver.sock
  - Hub URL: unix:///run/penta/hub.sock
  - Fallback to TCP for development if PENTA_TCP=1 env var is set.
  - Uses requests_unixsocket to communicate over unix:// endpoints.

Usage:
    penta install <package> [--source <source>] [--username <user>]
    penta remove <app>
    penta list
    penta search <term>
    penta mode set <mode>
    penta module list
    penta system info
"""

import os
import stat
import subprocess
import sys
import time
from pathlib import Path

import click
import requests
import requests_unixsocket

# ---------- Configuration ----------
# Use Unix sockets by default; set PENTA_TCP=1 to use TCP ports (dev)
USE_TCP = os.environ.get("PENTA_TCP", "0") == "1"

if USE_TCP:
    RESOLVER_URL = "http://localhost:8500"
    HUB_URL = "http://localhost:8400"
    PENTAD_URL = "http://localhost:8600"
else:
    RESOLVER_URL = "unix:///run/penta/resolver.sock"
    HUB_URL = "unix:///run/penta/hub.sock"
    PENTAD_URL = "unix:///run/penta/pentad.sock"  # pentad still TCP by default; see note

# ---------- Session setup ----------
def get_session():
    """Return a requests Session configured for Unix sockets if needed."""
    if RESOLVER_URL.startswith("unix://"):
        return requests_unixsocket.Session()
    else:
        session = requests.Session()
        return session

session = get_session()

# ---------- Helpers ----------
def check_resolver():
    """Verify that the Penta Resolver is reachable."""
    try:
        r = session.get(f"{RESOLVER_URL}/api/v1/health", timeout=2)
        r.raise_for_status()
    except Exception:
        click.echo("Cannot connect to Penta Resolver. Is it running?")
        sys.exit(1)

def create_wrapper_script(app_name: str, container: str, exec_name: str, is_windows: bool) -> Path:
    """Create a wrapper script in ~/.local/bin for the installed application."""
    bin_dir = Path.home() / ".local" / "bin"
    bin_dir.mkdir(parents=True, exist_ok=True)
    wrapper_path = bin_dir / app_name
    suffix = 0
    base = app_name
    while wrapper_path.exists():
        suffix += 1
        app_name = f"{base}_{suffix}"
        wrapper_path = bin_dir / app_name

    launch = f"box64 wine {exec_name}" if is_windows else exec_name
    script = f"""#!/bin/bash
# Penta OS wrapper for {app_name}
exec distrobox enter {container} -- {launch} "$@"
"""
    wrapper_path.write_text(script)
    wrapper_path.chmod(wrapper_path.stat().st_mode | stat.S_IEXEC | stat.S_IXGRP | stat.S_IXOTH)
    click.echo(f"  Wrapper created: {wrapper_path}")
    return wrapper_path

def create_desktop_file(name: str, wrapper_path: Path, icon: str = "") -> Path:
    """Create a .desktop file for the application."""
    desktop_dir = Path.home() / ".local" / "share" / "applications"
    desktop_dir.mkdir(parents=True, exist_ok=True)
    desktop_file = desktop_dir / f"{name.replace(' ', '_')}.desktop"
    content = f"""[Desktop Entry]
Name={name}
Exec={wrapper_path}
Icon={icon}
Type=Application
Terminal=false
Categories=Utility;
"""
    desktop_file.write_text(content)
    desktop_file.chmod(0o755)
    subprocess.run(["update-desktop-database", str(desktop_dir)], capture_output=True)
    click.echo(f"  Desktop entry: {desktop_file}")
    return desktop_file

def ensure_path_in_profile():
    """Add ~/.local/bin to PATH in .profile if not present."""
    profile = Path.home() / ".profile"
    line = 'export PATH="$HOME/.local/bin:$PATH"'
    if profile.exists():
        content = profile.read_text()
        if line not in content:
            with profile.open("a") as f:
                f.write(f"\n# Penta OS\n{line}\n")
    else:
        profile.write_text(f"{line}\n")
    click.echo(f"  Added {Path.home() / '.local' / 'bin'} to PATH in {profile}")

# ---------- CLI ----------
@click.group()
def cli():
    """Penta OS - The Universal Package Manager"""

@cli.command()
@click.argument("package")
@click.option("--source", "-s", default="auto")
@click.option("--username", "-u", default=None)
def install(package, source, username):
    """Install a package from any supported ecosystem."""
    check_resolver()
    payload = {"package": package, "source": source}
    if username:
        payload["username"] = username
    else:
        payload["username"] = os.getlogin()

    try:
        r = session.post(f"{RESOLVER_URL}/api/v1/install", json=payload)
        r.raise_for_status()
        task_id = r.json()["task_id"]
        click.echo(f"Installation started. Task ID: {task_id}")

        printed_logs = set()
        with click.progressbar(length=100, label="Installing") as bar:
            last_progress = 0
            while True:
                time.sleep(0.5)
                tr = session.get(f"{RESOLVER_URL}/api/v1/task/{task_id}")
                task = tr.json()
                new_progress = task.get("progress", 0)
                bar.update(new_progress - last_progress)
                last_progress = new_progress
                for line in task.get("log", [])[-3:]:
                    if line and line not in printed_logs:
                        click.echo(f"  {line}")
                        printed_logs.add(line)
                if task["status"] in ("completed", "failed"):
                    bar.update(100 - last_progress)
                    click.echo(f"\nStatus: {task['status']}")
                    if task["status"] == "completed" and task.get("result"):
                        meta = task["result"]
                        app_name = meta.get("name", package)
                        exec_name = meta.get("exec_name", app_name)
                        container = meta.get("container", "debian-stable")
                        is_win = meta.get("is_windows", False)
                        icon = meta.get("icon_url", "")
                        wrapper = create_wrapper_script(exec_name, container, exec_name, is_win)
                        create_desktop_file(app_name, wrapper, icon)
                        ensure_path_in_profile()
                        click.echo(f"'{app_name}' installed and available globally.")
                    elif task["status"] == "failed":
                        sys.exit(1)
                    break
    except Exception as e:
        click.echo(f"Error: {e}")
        sys.exit(1)

@cli.command()
@click.argument("app")
def remove(app):
    """Remove an installed application."""
    check_resolver()
    try:
        r = session.post(f"{RESOLVER_URL}/api/v1/uninstall/{app}")
        r.raise_for_status()
        click.echo(f"'{app}' removed.")
    except Exception as e:
        click.echo(f"Error: {e}")
        sys.exit(1)

@cli.command("list")
def list_apps():
    """List all installed applications."""
    check_resolver()
    try:
        r = session.get(f"{RESOLVER_URL}/api/v1/installed")
        r.raise_for_status()
        apps = r.json().get("installed", [])
        if not apps:
            click.echo("No applications installed.")
            return
        for app in apps:
            click.echo(f"  {app['name']}")
    except Exception as e:
        click.echo(f"Error: {e}")

@cli.command()
@click.argument("term")
def search(term):
    """Search for a package across all repositories."""
    try:
        r = session.get(f"{HUB_URL}/api/v1/search", params={"q": term, "limit": 10})
        r.raise_for_status()
        results = r.json().get("results", [])
        if not results:
            click.echo("No results found.")
            return
        for pkg in results:
            click.echo(f"{pkg['name']} ({pkg['source']}) - {pkg.get('version','?')} : {pkg.get('description','')}")
    except Exception as e:
        click.echo(f"Error: {e}")

@cli.group()
def mode():
    """Manage Penta OS mode."""

@mode.command("set")
@click.argument("mode_name")
def mode_set(mode_name):
    """Switch system mode."""
    check_resolver()
    try:
        r = session.post(f"{RESOLVER_URL}/api/v1/mode/switch?mode={mode_name}")
        r.raise_for_status()
        click.echo(f"Mode switched to '{mode_name}'.")
    except Exception as e:
        click.echo(f"Error: {e}")

@cli.group()
def module():
    """Interact with hardware modules."""

@module.command("list")
def module_list():
    """List connected hardware modules."""
    try:
        r = session.get(f"{PENTAD_URL}/api/v1/status")
        r.raise_for_status()
        data = r.json()
        modules = data.get("modules", [])
        if not modules:
            click.echo("No modules connected.")
        for mod in modules:
            click.echo(f"  {mod.get('type','unknown')} at {mod.get('addr','?')} (serial: {mod.get('serial','?')})")
    except Exception:
        click.echo("Cannot reach pentad daemon.")

@cli.group()
def system():
    """System information and utilities."""

@system.command("info")
def system_info():
    """Show system health and resource usage."""
    hub_ok = res_ok = pentad_ok = False
    try:
        r = session.get(f"{HUB_URL}/api/v1/health")
        hub_ok = r.status_code == 200
    except Exception:
        pass
    try:
        r = session.get(f"{RESOLVER_URL}/api/v1/health")
        res_ok = r.status_code == 200
    except Exception:
        pass
    try:
        r = session.get(f"{PENTAD_URL}/api/v1/status")
        pentad_data = r.json()
        pentad_ok = True
    except Exception:
        pentad_data = {}
    click.echo(f"Penta Hub: {'running' if hub_ok else 'down'}")
    click.echo(f"Penta Resolver: {'running' if res_ok else 'down'}")
    click.echo(f"pentad: {'running' if pentad_ok else 'down'}")
    if pentad_ok:
        modules = pentad_data.get("modules", [])
        click.echo(f"Connected modules: {len(modules)}")

if __name__ == "__main__":
    cli()
