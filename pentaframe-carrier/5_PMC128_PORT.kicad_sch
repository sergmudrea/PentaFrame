  ; Земля на всех GND пинах (A1,A4,A7,A10,A14,A17,A20,A24,A25,A29,A30,B4,B10,B13,B24,B29,B30,C30,D30)
  (power_symbol "GND" (at 100 100))
  (wire (pts (xy 150 100) (xy 100 100)))
  (global_label "GND_PMC" (at 150 100))

  ; === ESD защита (упрощённо показаны линии от порта до ESD, потом дальше) ===
  ; U30: A2,A3,A5,A6,A12,A13,A15,A16 (первые 8 высокоскоростных линий)
  (wire (pts (xy 150 110) (xy 100 400))) (wire (pts (xy 150 112) (xy 100 400)))
  (wire (pts (xy 150 114) (xy 100 400))) (wire (pts (xy 150 116) (xy 100 400)))
  ; U31 ...
  (wire (pts (xy 150 122) (xy 200 400))) (wire (pts (xy 150 124) (xy 200 400)))
  (wire (pts (xy 150 126) (xy 200 400))) (wire (pts (xy 150 128) (xy 200 400)))
  ; U32 ...
  (wire (pts (xy 150 170) (xy 300 400))) (wire (pts (xy 150 172) (xy 300 400)))
  (wire (pts (xy 150 174) (xy 300 400))) (wire (pts (xy 150 176) (xy 300 400)))
  ; U33 ...
  (wire (pts (xy 150 210) (xy 400 400))) (wire (pts (xy 150 212) (xy 400 400)))
  (wire (pts (xy 150 218) (xy 400 400))) (wire (pts (xy 150 220) (xy 400 400)))

  (power_symbol "GND" (at 100 420))
  (wire (pts (xy 100 400) (xy 100 420)))   ; U30 GND
  (power_symbol "GND" (at 200 420))
  (wire (pts (xy 200 400) (xy 200 420)))   ; U31 GND
  (power_symbol "GND" (at 300 420))
  (wire (pts (xy 300 400) (xy 300 420)))   ; U32 GND
  (power_symbol "GND" (at 400 420))
  (wire (pts (xy 400 400) (xy 400 420)))   ; U33 GND

  ; === Буфер I2C для модулей (PCA9517) ===
  (wire (pts (xy 600 300) (xy 600 320)))
  (global_label "I2C1_SDA_MASTER" (at 600 320))
  (wire (pts (xy 600 340) (xy 600 360)))
  (global_label "I2C1_SCL_MASTER" (at 600 360))
  (wire (pts (xy 600 300) (xy 550 300)))
  (wire (pts (xy 550 300) (xy 550 320)))
  (wire (pts (xy 550 320) (xy 550 300))) ; SDA1 <-> MODULE_DETECT линия
  (global_label "MODULE_DETECT" (at 550 320))
  (wire (pts (xy 600 280) (xy 600 260)))
  (global_label "I2C1_SCL_MODULE" (at 600 260))
  (wire (pts (xy 600 270) (xy 600 250)))
  (global_label "I2C1_SDA_MODULE" (at 600 250))

  ; Питание PCA9517
  (wire (pts (xy 600 300) (xy 600 380)))
  (power_symbol "+3.3V" (at 600 380))
  (wire (pts (xy 600 300) (xy 600 400)))
  (power_symbol "GND" (at 600 400))

  ; === EEPROM модуля ===
  (wire (pts (xy 600 450) (xy 600 430)))
  (wire (pts (xy 600 430) (xy 600 250))) ; SDA
  (wire (pts (xy 600 450) (xy 600 470)))
  (wire (pts (xy 600 470) (xy 600 260))) ; SCL
  (wire (pts (xy 600 450) (xy 600 490)))
  (power_symbol "+3.3V" (at 600 490))
  (wire (pts (xy 600 450) (xy 600 510)))
  (power_symbol "GND" (at 600 510))
  (wire (pts (xy 600 350) (xy 600 330))) ; A0/A1/A2 GND
  (power_symbol "GND" (at 600 330))

  ; === Подтяжки I2C (к основной шине) ===
  (wire (pts (xy 550 350) (xy 550 370)))
  (power_symbol "+3.3V" (at 550 370))
  (wire (pts (xy 550 350) (xy 600 300))) ; подтяжка SDA
  (wire (pts (xy 550 400) (xy 550 420)))
  (power_symbol "+3.3V" (at 550 420))
  (wire (pts (xy 550 400) (xy 600 340))) ; подтяжка SCL
)
