  (wire (pts (xy 150 148) (xy 200 148))) (global_label "I2C0_SDA" (at 200 148))
  (wire (pts (xy 150 150) (xy 200 150))) (global_label "I2C0_SCL" (at 200 150))
  (wire (pts (xy 150 152) (xy 200 152))) (global_label "I2C1_SDA" (at 200 152))
