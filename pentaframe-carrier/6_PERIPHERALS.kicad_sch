  ; ==================== Размещение компонентов ====================
  (symbol (lib_id "Interface_Expansion:PCA9555PW") (at 150 150) (unit 1))
  (symbol (lib_id "MCU_STM32:STM32G030F6P6") (at 400 150) (unit 1))
  (symbol (lib_id "Sensor:BME688") (at 150 300) (unit 1))
  (symbol (lib_id "Sensor_IMU:ICM-42688-P") (at 400 300) (unit 1))
  (symbol (lib_id "Sensor_Current:INA219") (at 150 400) (unit 1))
  (symbol (lib_id "Sensor_Temperature:TMP102") (at 400 400) (unit 1))
  (symbol (lib_id "Memory_FRAM:MB85RC256V") (at 150 500) (unit 1))
  (symbol (lib_id "Connector_Generic:Conn_02x07_Odd_Even") (at 400 500) (unit 1))

  ; Развязка
  (symbol (lib_id "Device:C") (at 200 100) (unit 1) (property "Reference" "C501") (property "Value" "100nF"))
  (symbol (lib_id "Device:C") (at 250 100) (unit 1) (property "Reference" "C502") (property "Value" "100nF"))
  (symbol (lib_id "Device:R") (at 300 200) (unit 1) (property "Reference" "R502") (property "Value" "10k"))

  ; ==================== Соединения ====================
  ; === Питание и земля ===
  (power_symbol "GND" (at 50 50))
  (power_symbol "+3.3V" (at 50 100))

  ; PCA9555
  (wire (pts (xy 150 120) (xy 150 110))) (global_label "VCC_3V3_MCU" (at 150 110))
  (wire (pts (xy 150 180) (xy 150 190))) (power_symbol "GND" (at 150 190))
  (wire (pts (xy 150 150) (xy 100 150))) (global_label "I2C0_SCL" (at 100 150))
  (wire (pts (xy 150 160) (xy 100 160))) (global_label "I2C0_SDA" (at 100 160))
  (wire (pts (xy 150 170) (xy 100 170))) (global_label "GPIO_EXP_INT" (at 100 170))
  (wire (pts (xy 150 140) (xy 100 140))) (global_label "GPIO0_PCIE_RST" (at 100 140))
  (wire (pts (xy 150 130) (xy 100 130))) (global_label "GPIO1_USB_HUB_RST" (at 100 130))

  ; СУПЕРВИЗОР STM32G030
  (wire (pts (xy 400 120) (xy 400 110))) (global_label "VCC_3V3_MCU" (at 400 110))
  (wire (pts (xy 400 180) (xy 400 190))) (power_symbol "GND" (at 400 190))
  (wire (pts (xy 400 150) (xy 350 150))) (global_label "I2C0_SCL" (at 350 150))
  (wire (pts (xy 400 160) (xy 350 160))) (global_label "I2C0_SDA" (at 350 160))
  (wire (pts (xy 400 170) (xy 350 170))) (global_label "SUPERVISOR_INT" (at 350 170))
  (wire (pts (xy 400 130) (xy 350 130))) (global_label "SUPERVISOR_UART_TX" (at 350 130))
  (wire (pts (xy 400 140) (xy 350 140))) (global_label "SUPERVISOR_UART_RX" (at 350 140))
  (wire (pts (xy 400 100) (xy 400 90))) (global_label "SWD_CLK" (at 400 90))
  (wire (pts (xy 400 95) (xy 400 85))) (global_label "SWD_IO" (at 400 85))

  ; Датчики (все на общей I2C, адресация разная)
  (wire (pts (xy 150 300) (xy 100 300))) (global_label "I2C0_SDA" (at 100 300))
  (wire (pts (xy 150 310) (xy 100 310))) (global_label "I2C0_SCL" (at 100 310))
  (wire (pts (xy 150 330) (xy 150 340))) (power_symbol "+3.3V" (at 150 340))
  (wire (pts (xy 150 320) (xy 150 350))) (power_symbol "GND" (at 150 350))

  (wire (pts (xy 400 300) (xy 350 300))) (global_label "I2C0_SDA" (at 350 300))
  (wire (pts (xy 400 310) (xy 350 310))) (global_label "I2C0_SCL" (at 350 310))
  (wire (pts (xy 400 330) (xy 400 340))) (power_symbol "+3.3V" (at 400 340))
  (wire (pts (xy 400 320) (xy 400 350))) (power_symbol "GND" (at 400 350))

  ; INA219 (измерение тока батареи и 5V)
  (wire (pts (xy 150 400) (xy 100 400))) (global_label "I2C0_SDA" (at 100 400))
  (wire (pts (xy 150 410) (xy 100 410))) (global_label "I2C0_SCL" (at 100 410))
  (wire (pts (xy 150 420) (xy 150 430))) (power_symbol "+3.3V" (at 150 430))
  (wire (pts (xy 150 440) (xy 150 450))) (power_symbol "GND" (at 150 450))
  (wire (pts (xy 150 400) (xy 150 460))) (global_label "INA219_BAT_I" (at 150 460)) ; шунт между VIN+ и VIN-

  ; TMP102 (температура CM5)
  (wire (pts (xy 400 400) (xy 350 400))) (global_label "I2C0_SDA" (at 350 400))
  (wire (pts (xy 400 410) (xy 350 410))) (global_label "I2C0_SCL" (at 350 410))
  (wire (pts (xy 400 420) (xy 400 430))) (power_symbol "+3.3V" (at 400 430))
  (wire (pts (xy 400 440) (xy 400 450))) (power_symbol "GND" (at 400 450))

  ; FRAM (Crash Dumper)
  (wire (pts (xy 150 500) (xy 100 500))) (global_label "I2C0_SDA" (at 100 500))
  (wire (pts (xy 150 510) (xy 100 510))) (global_label "I2C0_SCL" (at 100 510))
  (wire (pts (xy 150 520) (xy 150 530))) (power_symbol "+3.3V" (at 150 530))
  (wire (pts (xy 150 540) (xy 150 550))) (power_symbol "GND" (at 150 550))

  ; DEV-заголовок (подключение к SWD и UART)
  (wire (pts (xy 400 500) (xy 400 480))) ; Pin1 = +3.3V
  (power_symbol "+3.3V" (at 400 480))
  (wire (pts (xy 400 500) (xy 400 520))) ; Pin2 = GND
  (power_symbol "GND" (at 400 520))
  (wire (pts (xy 400 540) (xy 400 560))) ; Pin3 = SWD_CLK
  (global_label "SWD_CLK" (at 400 560))
  (wire (pts (xy 400 550) (xy 400 570))) ; Pin4 = SWD_IO
  (global_label "SWD_IO" (at 400 570))
  (wire (pts (xy 400 580) (xy 400 600))) ; Pin5 = JTAG_TCK (резерв)
  (global_label "JTAG_TCK" (at 400 600))
  (wire (pts (xy 400 590) (xy 400 610))) ; Pin6 = JTAG_TMS
  (global_label "JTAG_TMS" (at 400 610))
  (wire (pts (xy 400 620) (xy 400 640))) ; Pin10 = USB_DN
  (global_label "USB_TO_DEV_DN" (at 400 640))
  (wire (pts (xy 400 630) (xy 400 650))) ; Pin11 = USB_DP
  (global_label "USB_TO_DEV_DP" (at 400 650))
  (wire (pts (xy 400 660) (xy 400 680))) ; Pin12 = UART_TX
  (global_label "SUPERVISOR_UART_TX" (at 400 680))
  (wire (pts (xy 400 670) (xy 400 690))) ; Pin13 = UART_RX
  (global_label "SUPERVISOR_UART_RX" (at 400 690))
  (wire (pts (xy 400 700) (xy 400 720))) ; Pin14 = GND
  (power_symbol "GND" (at 400 720))

  ; --- Подтяжка nRST STM32 ---
  (wire (pts (xy 300 200) (xy 300 180)))
  (wire (pts (xy 300 180) (xy 400 180))) ; к NRST (не показан явно, но обычно PA0)
  (wire (pts (xy 300 200) (xy 300 220)))
  (power_symbol "+3.3V" (at 300 220))

  ; --- Глобальные земли для развязки ---
  (power_symbol "GND" (at 200 120))
  (wire (pts (xy 200 100) (xy 200 120)))
  (power_symbol "GND" (at 250 120))
  (wire (pts (xy 250 100) (xy 250 120)))
)
