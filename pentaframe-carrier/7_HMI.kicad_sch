(kicad_sch (version 20240108) (generator "kicad_sch")
  (paper "A3")
  (title_block
    (title "PentaFrame - HMI (Display, Buttons, Encoder, Mode Slider, LEDs)")
    (date "2026-05-17")
    (rev "1.1")
    (company "PentaFrame Technologies")
  )

  (lib_symbols
    ; Стандартные символы питания
    (symbol "power:GND" (pin (name "1") (number "1")) (property "Reference" "#PWR") (property "Value" "GND"))
    (symbol "power:+3.3V" (pin (name "1") (number "1")) (property "Reference" "#PWR") (property "Value" "+3.3V"))
    (symbol "power:+5V" (pin (name "1") (number "1")) (property "Reference" "#PWR") (property "Value" "+5V"))
    (symbol "power:+1.8V" (pin (name "1") (number "1")) (property "Reference" "#PWR") (property "Value" "+1.8V"))

    ; SSD2828 – MIPI-DSI в RGB мост
    (symbol "Display:SSD2828"
      (pin (name "DSI_D0N") (number "1")) (pin (name "DSI_D0P") (number "2"))
      (pin (name "DSI_D1N") (number "3")) (pin (name "DSI_D1P") (number "4"))
      (pin (name "DSI_CLKN") (number "5")) (pin (name "DSI_CLKP") (number "6"))
      (pin (name "DSI_D2N") (number "7")) (pin (name "DSI_D2P") (number "8"))
      (pin (name "DSI_D3N") (number "9")) (pin (name "DSI_D3P") (number "10"))
      (pin (name "VDD") (number "11")) (pin (name "GND") (number "12"))
      (pin (name "R0") (number "13")) (pin (name "R1") (number "14"))
      (pin (name "R2") (number "15")) (pin (name "R3") (number "16"))
      (pin (name "R4") (number "17")) (pin (name "G0") (number "18"))
      (pin (name "G1") (number "19")) (pin (name "G2") (number "20"))
      (pin (name "G3") (number "21")) (pin (name "G4") (number "22"))
      (pin (name "G5") (number "23")) (pin (name "B0") (number "24"))
      (pin (name "B1") (number "25")) (pin (name "B2") (number "26"))
      (pin (name "B3") (number "27")) (pin (name "B4") (number "28"))
      (pin (name "HSYNC") (number "29")) (pin (name "VSYNC") (number "30"))
      (pin (name "DCLK") (number "31")) (pin (name "DEN") (number "32"))
      (pin (name "I2C_SCL") (number "33")) (pin (name "I2C_SDA") (number "34"))
      (property "Reference" "U43") (property "Value" "SSD2828")
      (property "Footprint" "Package_DFN_QFN:QFN-48-1EP_6x6mm_P0.4mm_EP4.2x4.2mm")
    )

    ; FT5336G – ёмкостный touch контроллер
    (symbol "Interface_Touch:FT5336G"
      (pin (name "SDA") (number "1")) (pin (name "SCL") (number "2"))
      (pin (name "INT") (number "3")) (pin (name "RST") (number "4"))
      (pin (name "VDD") (number "5")) (pin (name "GND") (number "6"))
      (property "Reference" "U44") (property "Value" "FT5336G")
      (property "Footprint" "Package_DFN_QFN:QFN-24-1EP_4x4mm_P0.5mm")
    )

    ; AP5724 – драйвер подсветки
    (symbol "Driver_LED:AP5724WG-7"
      (pin (name "VIN") (number "1")) (pin (name "SW") (number "2"))
      (pin (name "FB") (number "3")) (pin (name "EN") (number "4"))
      (pin (name "GND") (number "5"))
      (property "Reference" "U45") (property "Value" "AP5724WG-7")
      (property "Footprint" "Package_TO_SOT_SMD:SOT-23-5")
    )

    ; SK6812-MINI – RGB светодиод на кнопке
    (symbol "LED:SK6812-MINI"
      (pin (name "VDD") (number "1")) (pin (name "DIN") (number "2"))
      (pin (name "DOUT") (number "3")) (pin (name "GND") (number "4"))
      (property "Reference" "D3") (property "Value" "SK6812-MINI")
      (property "Footprint" "LED_SMD:LED_SK6812_MINI_3.5x3.5mm")
    )

    ; Кнопка питания (нормально разомкнутая)
    (symbol "Switch:SW_Push"
      (pin (name "1") (number "1")) (pin (name "2") (number "2"))
      (property "Reference" "SW3") (property "Value" "POWER_BUTTON")
      (property "Footprint" "Button_Switch_THT:SW_PUSH_6mm_H13mm")
    )

    ; Энкодер с кнопкой
    (symbol "Rotary_Encoder:Encoder_SW"
      (pin (name "A") (number "1")) (pin (name "B") (number "2"))
      (pin (name "C") (number "3")) (pin (name "SW") (number "4")) (pin (name "SW2") (number "5"))
      (property "Reference" "SW4") (property "Value" "ENCODER_WHEEL")
      (property "Footprint" "Rotary_Encoder:RotaryEncoder_Alps_EC11E")
    )

    ; ===== ЛОКАЛЬНЫЙ СИМВОЛ: Mode Slider (трёхпозиционный, двухполюсный) =====
    (symbol "PentaFrame:Mode_Slider_3P3T"
      (pin (name "COM1") (number "1"))    ; сигнальный общий (подтянут к 3.3V)
      (pin (name "NO1") (number "2"))     ; Normal (замкнут на GND в позиции Normal)
      (pin (name "NC1") (number "3"))     ; Stealth (замкнут на GND в позиции Stealth)
      (pin (name "COM2") (number "4"))    ; силовой общий (KILL_AIRGAP_N)
      (pin (name "NO2") (number "5"))     ; в Normal/Stealth замкнут на GND (радио вкл)
      (pin (name "NC2") (number "6"))     ; в Airgap разомкнут (радио выкл)
      (property "Reference" "SW5") (property "Value" "MODE_SLIDER")
      (property "Footprint" "PentaFrame:Mode_Slider_3P3T")
    )

    ; Пассивные элементы
    (symbol "Device:R" (pin (name "1") (number "1")) (pin (name "2") (number "2"))
      (property "Reference" "R") (property "Value" "10k") (property "Footprint" "Resistor_SMD:R_0402"))
    (symbol "Device:R" (pin (name "1") (number "1")) (pin (name "2") (number "2"))
      (property "Reference" "R") (property "Value" "470") (property "Footprint" "Resistor_SMD:R_0402"))
    (symbol "Device:C" (pin (name "1") (number "1")) (pin (name "2") (number "2"))
      (property "Reference" "C") (property "Value" "100nF") (property "Footprint" "Capacitor_SMD:C_0402"))
    (symbol "Device:C" (pin (name "1") (number "1")) (pin (name "2") (number "2"))
      (property "Reference" "C") (property "Value" "10uF") (property "Footprint" "Capacitor_SMD:C_0603"))
  )

  ; ==================== РАЗМЕЩЕНИЕ КОМПОНЕНТОВ ====================
  (symbol (lib_id "Display:SSD2828") (at 100 100) (unit 1))
  (symbol (lib_id "Interface_Touch:FT5336G") (at 350 100) (unit 1))
  (symbol (lib_id "Driver_LED:AP5724WG-7") (at 100 300) (unit 1))
  (symbol (lib_id "LED:SK6812-MINI") (at 350 300) (unit 1))

  (symbol (lib_id "Switch:SW_Push") (at 600 100) (unit 1))       ; SW3 – кнопка питания
  (symbol (lib_id "Rotary_Encoder:Encoder_SW") (at 600 250) (unit 1)) ; SW4 – энкодер
  (symbol (lib_id "PentaFrame:Mode_Slider_3P3T") (at 100 500) (unit 1)) ; SW5 – Mode Slider (два полюса)

  ; Пассивные элементы
  (symbol (lib_id "Device:R") (at 450 150) (unit 1) (property "Reference" "R600") (property "Value" "10k"))
  (symbol (lib_id "Device:R") (at 450 180) (unit 1) (property "Reference" "R601") (property "Value" "10k"))
  (symbol (lib_id "Device:R") (at 450 210) (unit 1) (property "Reference" "R602") (property "Value" "470"))
  (symbol (lib_id "Device:C") (at 200 200) (unit 1) (property "Reference" "C600") (property "Value" "100nF"))
  (symbol (lib_id "Device:C") (at 250 200) (unit 1) (property "Reference" "C601") (property "Value" "10uF"))

  ; Подтяжки для Mode Slider
  (symbol (lib_id "Device:R") (at 50 550) (unit 1) (property "Reference" "R603") (property "Value" "10k"))
  (symbol (lib_id "Device:R") (at 50 580) (unit 1) (property "Reference" "R604") (property "Value" "10k"))

  ; ==================== СОЕДИНЕНИЯ ====================

  ; === Питание ===
  (power_symbol "GND" (at 50 50))
  (power_symbol "+3.3V" (at 50 80))
  (power_symbol "+1.8V" (at 50 110))
  (power_symbol "+5V" (at 50 140))

  ; --- SSD2828 (MIPI-DSI to RGB) ---
  (wire (pts (xy 100 60) (xy 100 50)))  (global_label "DSI_D0N" (at 100 60))
  (wire (pts (xy 100 70) (xy 100 80)))  (global_label "DSI_D0P" (at 100 70))
  (wire (pts (xy 100 90) (xy 100 100))) (global_label "DSI_D1N" (at 100 90))
  (wire (pts (xy 100 100) (xy 100 110))) (global_label "DSI_D1P" (at 100 100))
  (wire (pts (xy 100 120) (xy 100 130))) (global_label "DSI_CLKN" (at 100 120))
  (wire (pts (xy 100 140) (xy 100 150))) (global_label "DSI_CLKP" (at 100 140))
  (wire (pts (xy 100 160) (xy 100 170))) (global_label "DSI_D2N" (at 100 160))
  (wire (pts (xy 100 180) (xy 100 190))) (global_label "DSI_D2P" (at 100 180))
  (wire (pts (xy 100 200) (xy 100 210))) (global_label "DSI_D3N" (at 100 200))
  (wire (pts (xy 100 220) (xy 100 230))) (global_label "DSI_D3P" (at 100 220))

  ; RGB выход
  (wire (pts (xy 100 250) (xy 50 250))) (global_label "LCD_R0" (at 50 250))
  (wire (pts (xy 100 260) (xy 50 260))) (global_label "LCD_G0" (at 50 260))
  (wire (pts (xy 100 270) (xy 50 270))) (global_label "LCD_B0" (at 50 270))
  (wire (pts (xy 100 280) (xy 50 280))) (global_label "LCD_HSYNC" (at 50 280))
  (wire (pts (xy 100 290) (xy 50 290))) (global_label "LCD_VSYNC" (at 50 290))
  (wire (pts (xy 100 300) (xy 50 300))) (global_label "LCD_DCLK" (at 50 300))
  (wire (pts (xy 100 310) (xy 50 310))) (global_label "LCD_DEN" (at 50 310))

  ; I2C
  (wire (pts (xy 100 320) (xy 100 330))) (global_label "DISP_I2C_SCL" (at 100 320))
  (wire (pts (xy 100 340) (xy 100 350))) (global_label "DISP_I2C_SDA" (at 100 340))

  ; Питание SSD2828
  (wire (pts (xy 100 360) (xy 100 370))) (power_symbol "+3.3V" (at 100 360))
  (wire (pts (xy 100 380) (xy 100 390))) (power_symbol "+1.8V" (at 100 380)) ; VDDIO=1.8V
  (wire (pts (xy 100 400) (xy 100 410))) (power_symbol "GND" (at 100 400))

  ; --- FT5336G (Touch) ---
  (wire (pts (xy 350 100) (xy 300 100))) (global_label "DISP_I2C_SCL" (at 300 100))
  (wire (pts (xy 350 110) (xy 300 110))) (global_label "DISP_I2C_SDA" (at 300 110))
  (wire (pts (xy 350 120) (xy 300 120))) (global_label "TOUCH_INT" (at 300 120))
  (wire (pts (xy 350 130) (xy 300 130))) (global_label "TOUCH_RST" (at 300 130))
  (wire (pts (xy 350 140) (xy 350 150))) (power_symbol "+3.3V" (at 350 140))
  (wire (pts (xy 350 160) (xy 350 170))) (power_symbol "GND" (at 350 160))

  ; --- AP5724 (WLED драйвер) ---
  (wire (pts (xy 100 450) (xy 50 450))) (global_label "VCC_5V0_PERIPH" (at 50 450))
  (wire (pts (xy 100 460) (xy 100 470))) (global_label "LCD_BL_PWM" (at 100 460)) ; EN = PWM от GPIO
  (wire (pts (xy 100 480) (xy 100 490))) (global_label "LCD_BL_FB" (at 100 480)) ; FB = катод LED
  (wire (pts (xy 100 500) (xy 100 510))) (power_symbol "GND" (at 100 500))

  ; --- SK6812-MINI (RGB LED) ---
  (wire (pts (xy 350 300) (xy 350 280))) (power_symbol "+5V" (at 350 280))
  (wire (pts (xy 350 300) (xy 350 320))) (global_label "LED_RGB_DIN" (at 350 320))
  (wire (pts (xy 350 340) (xy 350 360))) (power_symbol "GND" (at 350 340))

  ; --- POWER_BUTTON (SW3) ---
  (wire (pts (xy 600 100) (xy 550 100))) (global_label "POWER_BUTTON" (at 550 100))
  (wire (pts (xy 600 120) (xy 600 130))) (power_symbol "GND" (at 600 120))
  ; Подтяжка кнопки
  (symbol (lib_id "Device:R") (at 650 100) (unit 1) (property "Reference" "R605") (property "Value" "10k"))
  (wire (pts (xy 600 100) (xy 650 100)))
  (wire (pts (xy 650 100) (xy 680 100)))
  (power_symbol "+3.3V" (at 680 100))

  ; --- ENCODER (SW4) ---
  (wire (pts (xy 600 250) (xy 550 250))) (global_label "ENCODER_A" (at 550 250))
  (wire (pts (xy 600 260) (xy 550 260))) (global_label "ENCODER_B" (at 550 260))
  (wire (pts (xy 600 270) (xy 550 270))) (global_label "ENCODER_BTN" (at 550 270))
  (wire (pts (xy 600 280) (xy 600 290))) (power_symbol "GND" (at 600 280))
  ; Подтяжки энкодера
  (symbol (lib_id "Device:R") (at 680 250) (unit 1) (property "Reference" "R606") (property "Value" "10k"))
  (symbol (lib_id "Device:R") (at 680 260) (unit 1) (property "Reference" "R607") (property "Value" "10k"))
  (symbol (lib_id "Device:R") (at 680 270) (unit 1) (property "Reference" "R608") (property "Value" "10k"))
  (wire (pts (xy 680 250) (xy 700 250))) (power_symbol "+3.3V" (at 700 250))
  (wire (pts (xy 680 260) (xy 700 260))) (power_symbol "+3.3V" (at 700 260))
  (wire (pts (xy 680 270) (xy 700 270))) (power_symbol "+3.3V" (at 700 270))
  (wire (pts (xy 600 250) (xy 680 250)))
  (wire (pts (xy 600 260) (xy 680 260)))
  (wire (pts (xy 600 270) (xy 680 270)))

  ; ==================== MODE SLIDER (ПОЛНЫЙ УЗЕЛ) ====================
  ; SW5 – двухполюсный трёхпозиционный переключатель
  ; Полюс 1 (сигнальный): различает Normal и Stealth
  ; Полюс 2 (силовой): аппаратный Airgap (разрыв питания радио)

  ; COM1 подтянут к +3.3V
  (wire (pts (xy 100 500) (xy 50 500))) (global_label "MODE_SLIDER_COM1" (at 50 500))  ; COM1
  (symbol (lib_id "Device:R") (at 50 550) (unit 1)) ; R603
  (wire (pts (xy 50 550) (xy 30 550))) (power_symbol "+3.3V" (at 30 550))
  (wire (pts (xy 50 550) (xy 50 540)))  (wire (pts (xy 50 540) (xy 50 500))) ; соединение COM1 – R603 – 3.3V

  ; NO1 – замкнут на GND в позиции Normal -> линия MODE_NORMAL_n = 0
  (wire (pts (xy 100 510) (xy 100 520))) (global_label "MODE_NORMAL_n" (at 100 520)) ; NO1
  (power_symbol "GND" (at 100 530)) (wire (pts (xy 100 510) (xy 100 530))) ; NO1 к GND

  ; NC1 – замкнут на GND в позиции Stealth -> линия MODE_STEALTH_n = 0
  (wire (pts (xy 100 540) (xy 100 550))) (global_label "MODE_STEALTH_n" (at 100 550)) ; NC1
  (power_symbol "GND" (at 100 560)) (wire (pts (xy 100 540) (xy 100 560))) ; NC1 к GND

  ; Обе линии подтянуты к +3.3V (когда не замкнуты, на них 1)
  (symbol (lib_id "Device:R") (at 50 580) (unit 1)) ; R604 для MODE_STEALTH_n
  (wire (pts (xy 50 580) (xy 50 570))) (wire (pts (xy 50 570) (xy 50 550))) ; подтяжка к 3.3V
  (wire (pts (xy 50 580) (xy 80 580))) (wire (pts (xy 80 580) (xy 80 550))) (wire (pts (xy 80 550) (xy 100 550))) ; подключение к линии STEALTH_n
  ; Для MODE_NORMAL_n используем отдельный резистор? Нет, на линии MODE_NORMAL_n уже есть подтяжка через R603? R603 подключен к COM1, а COM1 соединяется с NO1/NC1 только в соответствующих позициях. Нам нужна подтяжка на каждой сигнальной линии. Сделаем явно:
  (symbol (lib_id "Device:R") (at 30 520) (unit 1) (property "Reference" "R609") (property "Value" "10k"))
  (wire (pts (xy 30 520) (xy 30 500))) (power_symbol "+3.3V" (at 30 500))
  (wire (pts (xy 30 520) (xy 50 520))) (wire (pts (xy 50 520) (xy 100 520))) ; подтяжка MODE_NORMAL_n

  ; Аналогично для MODE_STEALTH_n (уже есть R604)

  ; Полюс 2 (силовой Airgap)
  (wire (pts (xy 100 600) (xy 100 610))) (global_label "KILL_AIRGAP_N" (at 100 610)) ; COM2
  ; NO2 – в Normal/Stealth замкнут на GND -> KILL_AIRGAP_N = 0
  (wire (pts (xy 100 620) (xy 100 630))) (global_label "AIRGAP_NO2" (at 100 630)) ; NO2
  (power_symbol "GND" (at 100 640)) (wire (pts (xy 100 620) (xy 100 640)))
  ; NC2 – в Airgap разомкнут (KILL_AIRGAP_N подтянут к 3.3V -> радио выкл)
  ; на схеме просто оставляем NC2 неподключённым, а COM2 имеет подтяжку к 3.3V.
  (symbol (lib_id "Device:R") (at 80 650) (unit 1) (property "Reference" "R610") (property "Value" "10k"))
  (wire (pts (xy 80 650) (xy 80 670))) (power_symbol "+3.3V" (at 80 670))
  (wire (pts (xy 80 650) (xy 100 650))) (wire (pts (xy 100 650) (xy 100 610))) ; подтяжка KILL_AIRGAP_N

  ; Таким образом:
  ; Normal: COM1-NO1 замкнут → MODE_NORMAL_n = 0, MODE_STEALTH_n = 1 (подтяжка)
  ; Stealth: COM1-NC1 замкнут → MODE_STEALTH_n = 0, MODE_NORMAL_n = 1
  ; Airgap: оба сигнальных контакта разомкнуты → MODE_NORMAL_n = 1, MODE_STEALTH_n = 1;
  ;         COM2-NO2 разомкнут → KILL_AIRGAP_N = 1 (подтяжка), радио питание отключено.

  ; Земля для всего узла
  (power_symbol "GND" (at 200 700))
)
