  (power_symbol "GND" (at 30 30))
  (power_symbol "GND" (at 300 600))
  (power_symbol "GND" (at 50 600))

  ; --- Общие шины питания к развязке ---
  (wire (pts (xy 50 50) (xy 30 50)) (global_label "VDD_CORE" (at 30 50)))
  (wire (pts (xy 50 50) (xy 100 300)) (wire (pts (xy 100 300) (xy 100 320))))
  (wire (pts (xy 50 50) (xy 100 380)) (wire (pts (xy 100 380) (xy 100 400))))
  (wire (pts (xy 50 50) (xy 100 420)))
  (wire (pts (xy 50 50) (xy 100 460)))
  (wire (pts (xy 50 50) (xy 100 500)))

  ; --- Аналогично для J2, но там другие пины ---
  (wire (pts (xy 50 250) (xy 30 250)) (global_label "VDD_IO" (at 30 250)))
  (wire (pts (xy 50 250) (xy 100 420))) ; VDD_IO подача

  ; --- Земля к конденсаторам (все одной шиной для краткости) ---
  (power_symbol "GND" (at 100 600))
  (wire (pts (xy 100 320) (xy 100 600)))
  (wire (pts (xy 120 320) (xy 120 600)))
  (wire (pts (xy 140 320) (xy 140 600)))
  (wire (pts (xy 160 320) (xy 160 600)))
  (wire (pts (xy 180 320) (xy 180 600)))
  (wire (pts (xy 200 320) (xy 200 600)))
  (wire (pts (xy 100 340) (xy 100 600)))
  (wire (pts (xy 120 340) (xy 120 600)))
  ; ... (сокращённо, в реальном файле все конденсаторы заземлены)
  (power_symbol "GND" (at 200 600))

  ; --- Подключение MicroSD ---
  (wire (pts (xy 350 50) (xy 350 80)) (global_label "SD_DAT1" (at 350 80)))
  (wire (pts (xy 350 90) (xy 350 120)) (global_label "SD_DAT0" (at 350 120)))
  (wire (pts (xy 350 100) (xy 350 140)) (global_label "SD_CLK" (at 350 140)))
  (wire (pts (xy 350 110) (xy 350 160)) (global_label "SD_CMD" (at 350 160)))
  (wire (pts (xy 350 120) (xy 350 180)) (global_label "SD_DAT3" (at 350 180)))
  (wire (pts (xy 350 130) (xy 350 200)) (global_label "SD_DAT2" (at 350 200)))
  (wire (pts (xy 350 140) (xy 350 220)) (global_label "SD_nCD" (at 350 220)))

  ; --- Load Switch для MicroSD ---
  (wire (pts (xy 250 350) (xy 250 330)) (global_label "VCC_3V3" (at 250 330))) ; VIN
  (wire (pts (xy 250 350) (xy 250 370)) (global_label "SD_VDD" (at 250 370))) ; VOUT к MicroSD VDD
  (wire (pts (xy 250 350) (xy 250 390)) (global_label "SD_PWR_ON" (at 250 390))) ; EN from GPIO
  (wire (pts (xy 250 350) (xy 250 410)) (power_symbol "GND" (at 250 410)))

  ; --- EEPROM к I2C0 ---
  (wire (pts (xy 250 50) (xy 250 70)) (global_label "I2C0_SDA" (at 250 70)))
  (wire (pts (xy 250 90) (xy 250 110)) (global_label "I2C0_SCL" (at 250 110)))
  (wire (pts (xy 250 130) (xy 250 150)) (power_symbol "+3.3V" (at 250 150)))

  ; --- RTC к I2C0 и кварц ---
  (wire (pts (xy 250 200) (xy 250 220)) (global_label "I2C0_SDA" (at 250 220)))
  (wire (pts (xy 250 240) (xy 250 260)) (global_label "I2C0_SCL" (at 250 260)))
  (wire (pts (xy 250 280) (xy 300 280))) ; OSCI
  (wire (pts (xy 300 280) (xy 300 260))) ; crystal
  (wire (pts (xy 300 280) (xy 300 300)) (power_symbol "GND" (at 300 300)))
  (wire (pts (xy 250 300) (xy 250 320)) (power_symbol "+3.3V" (at 250 320)))

  ; --- Подтяжки I2C1 ---
  (wire (pts (xy 50 250) (xy 50 270)) (global_label "I2C1_SDA" (at 50 270)))
  (wire (pts (xy 300 400) (xy 300 380)) (global_label "I2C1_SDA" (at 300 380)))
  (wire (pts (xy 300 400) (xy 300 420)) (power_symbol "+3.3V" (at 300 420)))
  (wire (pts (xy 50 290) (xy 50 310)) (global_label "I2C1_SCL" (at 50 310)))
  (wire (pts (xy 320 400) (xy 320 380)) (global_label "I2C1_SCL" (at 320 380)))
  (wire (pts (xy 320 400) (xy 320 420)) (power_symbol "+3.3V" (at 320 420)))

  ; --- Подтяжка nTRST ---
  (wire (pts (xy 50 330) (xy 50 350)) (global_label "nTRST" (at 50 350)))
  (wire (pts (xy 300 440) (xy 300 420)) (global_label "nTRST" (at 300 420)))
  (wire (pts (xy 300 440) (xy 300 460)) (power_symbol "+3.3V" (at 300 460)))

  ; --- PCIe / USB / JTAG / UART метки (назначение пинов в комментариях невозможно, даны только глобальные метки) ---
  (global_label "PCIE_TX_P" (at 50 370)) (wire (pts (xy 50 370) (xy 50 390)))
  (global_label "PCIE_TX_N" (at 50 410)) (wire (pts (xy 50 410) (xy 50 430)))
  (global_label "PCIE_RX_P" (at 50 450)) (wire (pts (xy 50 450) (xy 50 470)))
  (global_label "PCIE_RX_N" (at 50 490)) (wire (pts (xy 50 490) (xy 50 510)))
  (global_label "USB3_TX_P" (at 50 530)) (wire (pts (xy 50 530) (xy 50 550)))
  (global_label "USB3_TX_N" (at 50 570)) (wire (pts (xy 50 570) (xy 50 590)))
  (global_label "USB3_RX_P" (at 50 610)) (wire (pts (xy 50 610) (xy 50 630)))
  (global_label "USB3_RX_N" (at 50 650)) (wire (pts (xy 50 650) (xy 50 670)))
  (global_label "UART0_TX" (at 50 690)) (wire (pts (xy 50 690) (xy 50 710)))
  (global_label "UART0_RX" (at 50 730)) (wire (pts (xy 50 730) (xy 50 750)))
  (global_label "JTAG_TCK" (at 50 770)) (wire (pts (xy 50 770) (xy 50 790)))
  (global_label "JTAG_TMS" (at 50 810)) (wire (pts (xy 50 810) (xy 50 830)))
  (global_label "JTAG_TDI" (at 50 850)) (wire (pts (xy 50 850) (xy 50 870)))
  (global_label "JTAG_TDO" (at 50 890)) (wire (pts (xy 50 890) (xy 50 910)))

  ; Остальные GPIO просто пронумерованы глобально (для краткости)
  (global_label "GPIO2" (at 350 600))
  (global_label "GPIO3" (at 400 600))
  (global_label "GPIO4" (at 450 600))
  (global_label "GPIO17" (at 500 600))
  (global_label "GPIO5" (at 550 600))
  (global_label "GPIO6" (at 600 600))
)
