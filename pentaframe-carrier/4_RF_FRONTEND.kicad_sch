  ; ==================== Соединения ====================
  ; --- Питание ---
  (power_symbol "+3.3VA" (at 50 50))
  (power_symbol "+1.8VA" (at 50 80))
  (power_symbol "GND" (at 50 120))
  (wire (pts (xy 50 50) (xy 80 50)) (global_label "VCC_LNA" (at 50 50)))
  (wire (pts (xy 50 80) (xy 80 80)) (global_label "VCC_1V8_RF" (at 50 80)))

  ; --- Антенный тракт Sub-1GHz ---
  (wire (pts (xy 50 200) (xy 80 200))) ; SMA1 Center
  (wire (pts (xy 80 200) (xy 80 220))) ; DC block C300
  (wire (pts (xy 80 220) (xy 120 220))) ; C300 -> SW1 RFC
  (wire (pts (xy 120 220) (xy 250 220))) ; SW1 RFC
  (wire (pts (xy 250 200) (xy 100 220))) ; SW1 RF1 -> CC1101 (через балун, упрощенно)
  (global_label "CC1101_RF" (at 100 220))
  (wire (pts (xy 250 180) (xy 350 180))) ; SW1 RF2 -> RDM6300
  (global_label "RDM6300_ANT" (at 350 180))
  (wire (pts (xy 250 240) (xy 100 280))) ; SW1 RF3 -> GPS
  (global_label "GPS_RF_IN" (at 100 280))
  ; SW1 RF4 зарезервирован

  ; --- Антенный тракт High-Band ---
  (wire (pts (xy 700 200) (xy 650 200))) ; SMA2 Center
  (wire (pts (xy 650 200) (xy 650 220))) ; DC block
  (symbol (lib_id "Device:C") (at 650 220) (unit 1) (property "Reference" "C305") (property "Value" "100pF"))
  (wire (pts (xy 650 220) (xy 600 220))) ; C305 -> SW2 RFC
  (wire (pts (xy 600 220) (xy 500 220))) ; SW2 RFC
  (wire (pts (xy 500 200) (xy 450 200))) ; SW2 RF1 -> ESP32 (через антенный переключатель)
  (global_label "ESP32_ANT" (at 450 200))
  (wire (pts (xy 500 180) (xy 450 180))) ; SW2 RF2 -> LNA
  (wire (pts (xy 450 180) (xy 350 180))) ; LNA input
  (wire (pts (xy 350 180) (xy 350 160))) ; LNA output -> RTL2832U RF_IN
  (wire (pts (xy 350 160) (xy 350 140))) ; RTL RF_IN
  (global_label "RTL_RF_IN" (at 350 140))
  ; SW2 RF3/RF4 зарезервированы

  ; --- LNA питание ---
  (wire (pts (xy 350 200) (xy 350 220))) ; VCC
  (global_label "VCC_LNA" (at 350 220))
  (wire (pts (xy 350 200) (xy 350 240))) ; GND
  (power_symbol "GND" (at 350 240))

  ; --- Управление коммутаторами ---
  (wire (pts (xy 250 260) (xy 100 260))) ; SW1 CTRL_A/B
  (global_label "RF_SW1_CTRL_A" (at 100 260))
  (wire (pts (xy 250 280) (xy 100 280)))
  (global_label "RF_SW1_CTRL_B" (at 100 280))
