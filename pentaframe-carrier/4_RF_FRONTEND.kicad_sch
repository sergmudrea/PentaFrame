  (wire (pts (xy 600 520) (xy 650 520)))
  (global_label "IR_TX_ANODE" (at 600 520))

  ; --- Развязка питания и земли ---
  (power_symbol "GND" (at 200 600))
  (wire (pts (xy 80 320) (xy 80 600)))
  (wire (pts (xy 80 280) (xy 80 600)))
  (wire (pts (xy 350 600) (xy 350 300)))
  (wire (pts (xy 350 300) (xy 350 320)))
