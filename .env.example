# Penta OS — Development Environment Variables
# Copy this file to .env and adjust values for local development.
# All variables are optional; defaults are defined in code/config files.

# ---------- Service Transport ----------
# Set to 1 to use TCP ports instead of Unix sockets (useful for Docker Compose or remote dev)
PENTA_TCP=1

# ---------- Configuration Path ----------
# Override the default configuration file location
PENTA_CONFIG=config/penta.conf.example

# ---------- Hub Settings ----------
# Override Hub endpoint (default: unix:///run/penta/hub.sock)
PENTA_HUB_ENDPOINT=http://localhost:8400
# Database path for Hub
PENTA_HUB_DB_PATH=/tmp/penta-hub-dev.db
# Reindex interval in seconds (default 21600 = 6h, set lower for dev)
PENTA_HUB_REFRESH=60

# ---------- Resolver Settings ----------
# Container engine: distrobox or docker
PENTA_RESOLVER_ENGINE=distrobox
# Temporary directory for installations
PENTA_RESOLVER_TEMP=/tmp/penta-install

# ---------- Logging ----------
# Log level: debug, info, warning, error
PENTA_LOG_LEVEL=debug

# ---------- Development Mode ----------
# Skip hardware checks (I2C, GPIO) for pentad
PENTAD_DEV_MODE=1
# Skip real sensors for psyched, use emulation
PSYCHED_DEV_MODE=1
